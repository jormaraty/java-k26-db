<configuration>

    <!-- Tulostus konsoliin -->
    <appender name="STDOUT" class="ch.qos.logback.core.ConsoleAppender">
        <encoder>
            <pattern>%d{HH:mm:ss.SSS} %-5level %logger{36} - %msg%n</pattern>
        </encoder>
    </appender>

    <!-- Root-logger: INFO-tasosta ylöspäin konsoliin -->
    <root level="INFO">
        <appender-ref ref="STDOUT" />
    </root>

    <!-- Hibernate-logit INFO-tasolla (voi olla redundanttikin, koska root on INFO) -->
    <logger name="org.hibernate" level="INFO" />
</configuration>
